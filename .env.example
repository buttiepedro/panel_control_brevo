# ============================================
# CONFIGURACIÓN DEL PANEL DE CONTROL - BREVO
# ============================================
# Copia este archivo a .env y ajusta los valores

# ============================================
# SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# BASE DE DATOS MONGODB
# ============================================
# LOCAL (desarrollo)
# MONGODB_URI=mongodb://localhost:27017/panel-brevo

# DOCKER COMPOSE (con autenticación)
MONGODB_URI=mongodb://admin:mongoadmin123@mongodb:27017/panel-brevo?authSource=admin

# REMOTO (producción - ejemplo)
# MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/panel-brevo?retryWrites=true&w=majority

# ============================================
# SEGURIDAD
# ============================================
# Contraseña única para acceder al panel
# Cambiar a una contraseña fuerte en producción
ADMIN_PASSWORD=tu_contraseña_aqui_123

# ============================================
# REDIS (Opcional - para n8n)
# ============================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# REDIS con Docker Compose:
# REDIS_HOST=redis
# REDIS_PORT=6379

# ============================================
# ENTORNO
# ============================================
# Opciones: development | production | test
NODE_ENV=production

# ============================================
# CORS Y SEGURIDAD
# ============================================
# Dominios permitidos para CORS
# CORS_ORIGIN=http://localhost:3000,https://tudominio.com

# ============================================
# LOGS
# ============================================
# DEBUG=panel:*
# LOG_LEVEL=info
